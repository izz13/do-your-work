{
  "manifest_version": 3,
  "name": "DO UR WORK — Focus & Task Tracker",
  "short_name": "DO UR WORK",
  "version": "1.0.0",
  "description": "Finish your work. Unlock the rest. Track tasks, build streaks, and run focus sessions.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open DO UR WORK"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs"]
}
